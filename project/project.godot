; Engine configuration file.
; It's best edited using the Godot Editor, but can be edited manually.
; It's formatted using INI syntax.

[application]

config/name="Hotel"
config/description="The Raid meets Hotline Miami in a satanic luxury hotel"
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.3", "Forward+")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/core/game_manager.gd"
EventBus="*res://scripts/core/event_bus.gd"
SaveManager="*res://scripts/core/save_manager.gd"
GoreSystem="*res://scripts/combat/gore_system.gd"
ScreenEffects="*res://scripts/effects/screen_effects.gd"
AudioManager="*res://scripts/audio/audio_manager.gd"
ArtifactRegistry="*res://scripts/core/artifact_registry.gd"
UpgradeRegistry="*res://scripts/core/upgrade_registry.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/vsync/vsync_mode=1


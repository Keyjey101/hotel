[layer_names]

2d_physics/layer_1="player_hurtbox"
2d_physics/layer_2="player_hitbox"
2d_physics/layer_3="enemy_hurtbox"
2d_physics/layer_4="enemy_hitbox"
2d_physics/layer_5="weapon_hitbox"
2d_physics/layer_6="projectile_hitbox"
2d_physics/layer_7="environment"
2d_physics/layer_8="throwable"

[rendering]

textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true

[debug]

gdscript/warnings/enable=true
gdscript/warnings/exclude_addons=false
gdscript/warnings/treat_warnings_as_errors=false
